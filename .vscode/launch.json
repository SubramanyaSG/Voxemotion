{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run app.py (Flask Web App)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "0"
      }
    },
    {
      "name": "Run train.py (Train Model)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
